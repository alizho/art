---
import ThemeToggle from './ThemeToggle.astro';

const socials = [
  { name: 'instagram↗', url: 'https://instagram.com/kiwiirii/' },
  { name: 'twitter↗', url: 'https://twitter.com/kiwiiri/' },
  { name: 'tiktok↗', url: 'https://tiktok.com/@wiwiirii/' },
];
---

<aside class="w-full lg:w-80 xl:w-96 lg:fixed lg:top-0 lg:left-0 lg:h-screen z-20 flex flex-col items-center justify-between px-8 py-12 lg:py-16">
  <div class="toggle-layer">
    <ThemeToggle />
  </div>
  <div class="flex flex-col items-center gap-6 w-full max-w-xs">
    <img
      src="/profile-light.webp"
      alt="Profile"
      class="profile-img profile-light w-24 h-24 rounded-full object-cover"
    />
    <img
      src="/profile-dark.webp"
      alt="Profile"
      class="profile-img profile-dark w-24 h-24 rounded-full object-cover"
    />

    <div class="text-center space-y-4 max-w-[14rem]">
      <p class="text-sm leading-relaxed" style="color: var(--color-text);">
        kiwi
      </p>
      <p class="text-sm leading-relaxed" style="color: var(--color-text);">
        illustrating and sometimes animating silly things in my free time c:
      </p>
    </div>

    <nav class="nav-links flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm">
      {socials.map((s) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link"
        >
          {s.name}
        </a>
      ))}
    </nav>

    <div class="dropdowns flex flex-col items-center gap-2 w-full max-w-[14rem] text-sm">
      <div class="dropdown">
        <button class="dropdown-toggle" aria-expanded="false">
          faq <span class="dropdown-arrow">›</span>
        </button>
        <div class="dropdown-content">
          <div>
            <p>what programs do you use?</p>
            <p class="answer">procreate / clip studio paint</p>
            <p>can i use your art?</p>
            <p class="answer">feel free to use as a profile picture or background, but please don't repost without credit</p>
            <p>do you take commissions?</p>
            <p class="answer">not currently, but maybe someday when i'm not as busy</p>
          </div>
        </div>
      </div>

      <div class="dropdown">
        <button class="dropdown-toggle" aria-expanded="false">
          about me <span class="dropdown-arrow">›</span>
        </button>
        <div class="dropdown-content">
          <div>
            <p class="answer">i'm currently a student in computer science, but spend much of my time doodling things in my head :p hoping to post more in the future and maybe booth somewhere someday</p>
            <p class="answer">into magdalena bay, silksong, cats, and painting ceramic</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="flex flex-col items-center gap-2 mt-12 lg:mt-0">
    <div class="footer-fish-wrap relative w-56 h-20">
      <video
        src="/footerfish-light.webm"
        autoplay
        loop
        muted
        playsinline
        class="footer-fish-light w-full h-full object-contain"
      />
      <video
        src="/footerfish-dark.webm"
        autoplay
        loop
        muted
        playsinline
        class="footer-fish-dark w-full h-full object-contain"
      />
      <span class="footer-ornament footer-ornament--a" aria-hidden="true">⋆ ｡ •</span>
      <span class="footer-ornament footer-ornament--b" aria-hidden="true">⊹｡˚</span>
      <span class="footer-ornament footer-ornament--c" aria-hidden="true"> ࣪ ˖</span>
    </div>
    <span class="text-xs" style="color: var(--color-text-muted);">
      .* thanks for swimming by ⋆｡˚
    </span>
  </footer>
</aside>

<style>
  .toggle-layer {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 30;
    padding: 1rem 1.5rem;
    pointer-events: auto;
  }

  .profile-dark {
    display: none;
  }

  :global(html.dark) .profile-light {
    display: none;
  }

  :global(html.dark) .profile-dark {
    display: block;
  }

  .footer-fish-light,
  .footer-fish-dark {
    position: absolute;
    inset: 0;
  }

  .footer-fish-light {
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  :global(html.dark) .footer-fish-light {
    opacity: 0;
  }

  .nav-link {
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.5s ease, opacity 0.5s ease;
  }

  .nav-link:hover {
    opacity: 1;
  }

  /* When any link in the nav is hovered, mute the others */
  .nav-links:has(.nav-link:hover) .nav-link:not(:hover) {
    color: var(--color-text-muted);
    opacity: 0.9;
  }

  @keyframes ornament-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .footer-ornament {
    z-index: 20;
    position: absolute;
    pointer-events: none;
    color: var(--color-link);
    font-size: 1.5rem;
    opacity: 1;
    line-height: 1;
    animation: ornament-float 4s ease-in-out infinite;
  }

  .footer-ornament--a {
    top: 0.25rem;
    left: 0.5rem;
    animation-duration: 1.8s;
    animation-delay: 0s;
    animation-timing-function: cubic-bezier(0.45, 0, 0.55, 1);
  }

  .footer-ornament--b {
    top: 0.5rem;
    right: 0.75rem;
    animation-duration: 2.4s;
    animation-delay: 0.7s;
    animation-timing-function: cubic-bezier(0.4, 0, 0.6, 1);
  }

  .footer-ornament--c {
    bottom: 0.35rem;
    left: 4.5rem;
    animation-duration: 1.2s;
    animation-delay: 0.3s;
    animation-timing-function: cubic-bezier(0.5, 0, 0.5, 1);
  }

  .dropdowns {
    margin-top: 0.25rem;
  }

  .dropdown {
    width: 100%;
  }

  .dropdown-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: 0.25rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-link);
    font-size: 0.875rem;
    font-family: inherit;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .dropdown-toggle:hover {
    opacity: 0.75;
  }

  .dropdown-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
    font-size: 1rem;
    line-height: 1;
  }

  .dropdown-toggle[aria-expanded="true"] .dropdown-arrow {
    transform: rotate(90deg);
  }

  .dropdown-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
    overflow: hidden;
    /* text-wrap: balance; */
  }

  .dropdown-content > div {
    overflow: hidden;
  }

  .dropdown-toggle[aria-expanded="true"] + .dropdown-content {
    grid-template-rows: 1fr;
  }

  .dropdown-content p {
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  .dropdown-content p.answer {
    color: var(--color-text);
    margin-top: 0.1rem;
    margin-bottom: 0.4rem;
  }
</style>

<script>
  document.querySelectorAll('.dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>
